{
  "name": "mqtt2ha",
  "version": "4.1.3",
  "license": "MIT",
  "private": false,
  "description": "Javascript library to create MQTT entities that are automatically discovered by Home Assistant.",
  "keywords": [
    "homeassistant",
    "home-assistant",
    "hass",
    "mqtt",
    "discovery",
    "mqtt-discovery"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "author": {
    "name": "Pascal Bourque",
    "email": "pascal@cosmos.moi"
  },
  "bugs": {
    "url": "https://github.com/bourquep/mysa2mqtt/issues"
  },
  "homepage": "https://github.com/bourquep/mysa2mqtt/tree/main/packages/mqtt2ha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bourquep/mysa2mqtt.git",
    "directory": "packages/mqtt2ha"
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "LICENSE.txt",
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=24.15.0"
  },
  "browser": false,
  "scripts": {
    "example": "tsx --watch ./test-environment/example.ts",
    "lint": "eslint --max-warnings 0 src/**/*.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsup",
    "build:docs": "typedoc"
  },
  "dependencies": {
    "mqtt": "5.15.2"
  },
  "devDependencies": {
    "pino": "10.3.1",
    "pino-pretty": "13.1.3"
  }
}
