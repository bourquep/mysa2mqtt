{
  "name": "mysa2mqtt-monorepo",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "description": "Monorepo for mysa2mqtt and its supporting libraries.",
  "author": {
    "name": "Pascal Bourque",
    "email": "pascal@cosmos.moi"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bourquep/mysa2mqtt.git"
  },
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w mqtt2ha && npm run build -w mysa-js-sdk && npm run build -w mysa2mqtt",
    "build:docs": "npm run build:docs --workspaces --if-present",
    "typecheck": "npm run build && npm run typecheck --workspaces --if-present",
    "lint": "eslint --max-warnings 0 \"packages/*/src/**/*.ts\"",
    "style-lint": "prettier -c .",
    "style-fix": "prettier -w .",
    "changeset": "changeset",
    "version-packages": "changeset version && npm install --package-lock-only",
    "release": "npm run build && changeset publish"
  },
  "overrides": {
    "minimatch@3.1.5": {
      "brace-expansion": "^2.0.2"
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.1",
    "@eslint/js": "9.39.5",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "eslint-plugin-jsdoc": "63.1.0",
    "eslint-plugin-tsdoc": "0.5.2",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "prettier-plugin-jsdoc": "1.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typedoc": "0.28.20",
    "typedoc-material-theme": "1.4.1",
    "typescript": "7.0.2",
    "typescript-eslint": "8.64.0"
  }
}
